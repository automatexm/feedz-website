# Environment Variables

# Uncomment and set these values if needed in the future

# Site URL (defaults to astro.config.mjs site value)
# PUBLIC_SITE_URL=https://feedzsxm.com

# WhatsApp Number (used for contact links)
# PUBLIC_WHATSAPP_NUMBER=17215810102

# Analytics / Third-party services (add when needed)
# PUBLIC_ANALYTICS_ID=
# PUBLIC_GOOGLE_TAG_ID=

# Note: This project uses static site generation.
# No sensitive API keys should be stored here.
