---
import Base from '../../layouts/Base.astro';
import DWPartnerBadge from '../../components/DWPartnerBadge.astro';
import { t } from '../../i18n/index';

const lang = 'fr' as const;
const tr = t(lang);
const waMessage = encodeURIComponent(tr.whatsapp.defaultMessage);
---

<Base title={tr.seo.about.title} description={tr.seo.about.description} lang={lang}>

  <!-- Page header -->
  <div style="background-color: #2D6A4F; padding: 3rem 1rem 2.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #F5F0E8; margin: 0;">
        {tr.about_page.heading}
      </h1>
    </div>
  </div>

  <!-- Story section -->
  <section style="padding: 3rem 1rem; background-color: #F5F0E8;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="story-inner">
        <div class="story-text">
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.625rem; font-weight: 700; color: #2C1A0E; margin: 0 0 1rem;">
            {tr.about_page.storyHeading}
          </h2>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; line-height: 1.75; color: #5C4A35; background: #EAE0CC; border-left: 3px solid #52B788; padding: 1rem 1.25rem; border-radius: 0 8px 8px 0; font-style: italic;">
            {tr.about_page.storyBody}
          </p>
        </div>
        <div class="story-photos">
          <div class="photo-placeholder" style="aspect-ratio: 4/3; border-radius: 12px; margin-bottom: 1rem;">
            <span>[Photo : devanture du magasin Feedz à Saint-Martin]</span>
          </div>
          <div class="photo-placeholder" style="aspect-ratio: 4/3; border-radius: 12px;">
            <span>[Photo : intérieur du magasin — rayons, sacs d'alimentation]</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet Ismaru -->
  <section style="background-color: #EAE0CC; padding: 3rem 1rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.625rem; font-weight: 700; color: #2C1A0E; margin: 0 0 2rem; text-align: center;">
        {tr.about_page.teamHeading}
      </h2>
      <div style="max-width: 560px; margin: 0 auto; text-align: center;">
        <div class="photo-placeholder" style="width: 200px; height: 200px; border-radius: 50%; margin: 0 auto 1.5rem; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
          <span style="font-size: 0.75rem;">[Photo : Ismaru Falbru]</span>
        </div>
        <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.375rem; font-weight: 700; color: #2C1A0E; margin: 0 0 0.25rem;">
          {tr.about_page.teamName}
        </h3>
        <div style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; font-weight: 600; color: #2D6A4F; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
          {tr.about_page.teamRole}
        </div>
        <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.0625rem; line-height: 1.65; color: #5C4A35; font-style: italic; margin: 0;">
          "{tr.about_page.teamQuote}"
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section style="padding: 3rem 1rem; background-color: #F5F0E8;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.625rem; font-weight: 700; color: #2C1A0E; margin: 0 0 2rem; text-align: center;">
        {tr.about_page.valuesHeading}
      </h2>
      <div class="values-grid">
        {tr.about_page.values.map(value => (
          <div style="background: #EAE0CC; border-radius: 12px; padding: 1.75rem; box-shadow: 0 2px 8px rgba(44,26,14,0.06);">
            <div style="font-size: 2rem; margin-bottom: 0.75rem;" aria-hidden="true">{value.icon}</div>
            <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.125rem; font-weight: 700; color: #2C1A0E; margin: 0 0 0.5rem;">
              {value.title}
            </h3>
            <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; line-height: 1.6; color: #5C4A35; margin: 0;">
              {value.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DW deep dive -->
  <section style="padding: 3rem 1rem; background-color: #EAE0CC;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.625rem; font-weight: 700; color: #2C1A0E; margin: 0 0 1.25rem;">
        {tr.about_page.dwHeading}
      </h2>
      <div class="dw-about-inner">
        <div style="flex: 1;">
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; line-height: 1.7; color: #5C4A35; margin: 0 0 1rem;">
            {tr.about_page.dwBody}
          </p>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; line-height: 1.6; color: #2D6A4F; font-weight: 600; border-left: 3px solid #2D6A4F; padding-left: 1rem; margin: 0 0 1.25rem;">
            {tr.about_page.dwCertified}
          </p>
          <a
            href="https://www.dommelschewatermolen.nl"
            target="_blank"
            rel="noopener noreferrer"
            style="color: #1B6CA8; font-size: 0.9375rem; font-family: 'Nunito Sans', system-ui, sans-serif; font-weight: 600;"
          >
            Visiter le site de Dommelsche Watermolen →
          </a>
        </div>
        <div style="flex-shrink: 0; min-width: 160px;">
          <div style="background: white; border: 1px solid #2D6A4F; border-radius: 8px; padding: 1.5rem; text-align: center;">
            <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; font-weight: 700; color: #2D6A4F; line-height: 1.3;">
              Dommelsche<br />Watermolen
            </div>
            <div style="font-size: 0.6875rem; color: #5C4A35; margin-top: 0.375rem; font-family: 'Nunito Sans', system-ui, sans-serif; letter-spacing: 0.05em; text-transform: uppercase;">
              Est. 1924 · GMP+
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA to contact -->
  <div style="background-color: #2D6A4F; padding: 2.5rem 1rem; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: #F5F0E8; margin: 0 0 0.75rem;">
        Venez nous voir à Saint-Martin
      </h3>
      <p style="font-family: 'Nunito Sans', system-ui, sans-serif; color: #EAE0CC; margin: 0 0 1.5rem;">
        Nous serons ravis de vous rencontrer. Passez au magasin ou écrivez-nous.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center;">
        <a
          href={`https://wa.me/17215810102?text=${waMessage}`}
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 0.5rem; background: #25D366; color: white; padding: 0.875rem 1.5rem; border-radius: 8px; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; text-decoration: none;"
        >
          WhatsApp
        </a>
        <a
          href={`/${lang}/contact/`}
          style="display: inline-flex; align-items: center; background: transparent; color: #F5F0E8; padding: 0.875rem 1.5rem; border-radius: 8px; border: 2px solid #F5F0E8; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; text-decoration: none;"
        >
          Page contact
        </a>
      </div>
    </div>
  </div>

</Base>

<style>
  .story-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .dw-about-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .story-inner { flex-direction: row; align-items: flex-start; }
    .story-text { flex: 1.1; }
    .story-photos { flex: 1; }
    .dw-about-inner { flex-direction: row; align-items: flex-start; gap: 2.5rem; }
    .values-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
