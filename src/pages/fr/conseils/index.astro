---
import Base from '../../../layouts/Base.astro';
import TipCard from '../../../components/TipCard.astro';
import { t } from '../../../i18n/index';
import { getCollection } from 'astro:content';

const lang = 'fr' as const;
const tr = t(lang);

const allTips = await getCollection('tips', ({ data }) => data.lang === 'fr');
const tips = allTips.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title={tr.seo.tips.title} description={tr.seo.tips.description} lang={lang}>

  <div style="background-color: #2D6A4F; padding: 3rem 1rem 2.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #F5F0E8; margin: 0 0 0.5rem;">
        {tr.tips.heading}
      </h1>
      <p style="font-family: 'Nunito Sans', system-ui, sans-serif; color: #EAE0CC; font-size: 1rem; margin: 0;">
        {tr.tips.subheading}
      </p>
    </div>
  </div>

  <div style="max-width: 1100px; margin: 0 auto; padding: 2.5rem 1rem;">
    <div class="tips-grid">
      {tips.map(tip => (
        <TipCard
          lang={lang}
          title={tip.data.title}
          description={tip.data.description}
          category={tip.data.category}
          date={tip.data.date}
          readTime={tip.data.readTime}
          slug={tip.id.replace(/^fr\//, '')}
          minRead={tr.tips.minRead}
          readMoreLabel={tr.tips.readMore.replace(' →', '')}
        />
      ))}
    </div>
  </div>

  <!-- WhatsApp CTA -->
  <div style="background-color: #D4A017; padding: 2.5rem 1rem; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.375rem; font-weight: 700; color: #2C1A0E; margin: 0 0 0.75rem;">
        Une question sur votre animal ?
      </h3>
      <p style="font-family: 'Nunito Sans', system-ui, sans-serif; color: #2C1A0E; margin: 0 0 1.25rem; font-size: 1rem;">
        Notre équipe est là pour vous aider. Envoyez-nous un message sur WhatsApp.
      </p>
      <a
        href={`https://wa.me/17215810102?text=${encodeURIComponent(tr.whatsapp.defaultMessage)}`}
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #25D366; color: white; padding: 0.875rem 1.5rem; border-radius: 8px; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; text-decoration: none;"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>
  </div>

</Base>

<style>
  .tips-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .tips-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .tips-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
