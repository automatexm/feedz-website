---
import BlogPost from '../../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tips = await getCollection('tips', ({ data }) => data.lang === 'fr');
  return tips.map(tip => ({
    params: { slug: tip.id.replace(/^fr\//, '') },
    props: { tip },
  }));
}

const { tip } = Astro.props;
const { Content } = await render(tip);
---

<BlogPost
  title={tip.data.title}
  description={tip.data.description}
  lang="fr"
  date={tip.data.date}
  category={tip.data.category}
  readTime={tip.data.readTime}
>
  <Content />
</BlogPost>