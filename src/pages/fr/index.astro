---
import Base from '../../layouts/Base.astro';
import DWPartnerBadge from '../../components/DWPartnerBadge.astro';
import LocationStrip from '../../components/LocationStrip.astro';
import TipCard from '../../components/TipCard.astro';
import { t } from '../../i18n/index';
import { getCollection } from 'astro:content';

const lang = 'fr' as const;
const tr = t(lang);

const allTips = await getCollection('tips', ({ data }) => data.lang === 'fr');
const latestTips = allTips.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 2);

const waMessage = encodeURIComponent(tr.whatsapp.defaultMessage);
---

<Base title={tr.seo.home.title} description={tr.seo.home.description} lang={lang}>

  <!-- HERO -->
  <section style="background-color: #F5F0E8; padding: 2rem 1rem 2.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="hero-inner">
        <div class="hero-photo">
          <div class="photo-placeholder" style="aspect-ratio: 4/3; border-radius: 12px; overflow: hidden;">
            <span>[Photo : devanture du magasin Feedz à Saint-Martin]</span>
          </div>
        </div>
        <div class="hero-text">
          <div style="display: inline-block; background: #EAE0CC; color: #2D6A4F; font-size: 0.75rem; font-weight: 700; padding: 0.3rem 0.75rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; font-family: 'Nunito Sans', system-ui, sans-serif;">
            Saint-Martin
          </div>
          <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 5vw, 2.75rem); font-weight: 700; color: #2C1A0E; line-height: 1.2; margin: 0 0 1rem;">
            {tr.hero.headline}
          </h1>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1.0625rem; line-height: 1.6; color: #5C4A35; margin: 0 0 1.75rem;">
            {tr.hero.subline}
          </p>
          <div class="hero-buttons">
            <a
              href={`https://wa.me/17215810102?text=${waMessage}`}
              target="_blank"
              rel="noopener noreferrer"
              style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; background: #25D366; color: white; padding: 0.9375rem 1.5rem; border-radius: 8px; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; text-decoration: none; min-height: 48px;"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {tr.hero.ctaWhatsApp}
            </a>
            <a
              href={`/${lang}/produits/`}
              style="display: flex; align-items: center; justify-content: center; background: transparent; color: #2D6A4F; padding: 0.9375rem 1.5rem; border-radius: 8px; border: 2px solid #2D6A4F; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; text-decoration: none; min-height: 48px;"
            >
              {tr.hero.ctaProducts}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT CATEGORIES -->
  <section style="padding: 3rem 1rem; background-color: #F5F0E8;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="margin-bottom: 2rem;">
        <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #2C1A0E; margin: 0 0 0.5rem;">
          {tr.categories.heading}
        </h2>
        <p style="font-family: 'Nunito Sans', system-ui, sans-serif; color: #5C4A35; font-size: 1rem; margin: 0;">
          {tr.categories.subheading}
        </p>
      </div>
      <div class="cat-grid">
        {tr.categories.items.map(cat => (
          <a
            href={`/${lang}/produits/#${cat.id}`}
            style="background: #EAE0CC; border-radius: 12px; box-shadow: 0 2px 8px rgba(44,26,14,0.08); overflow: hidden; text-decoration: none; display: block;"
          >
            <div class="photo-placeholder" style="aspect-ratio: 4/3;">
              <span>[Photo : {cat.label}]</span>
            </div>
            <div style="padding: 1rem;">
              <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; font-weight: 700; color: #2C1A0E; margin: 0 0 0.25rem;">{cat.label}</h3>
              <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; color: #5C4A35; margin: 0;">{cat.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <DWPartnerBadge lang={lang} />

  <!-- ABOUT INTRO -->
  <section style="padding: 3rem 1rem; background-color: #F5F0E8;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="about-inner">
        <div class="about-photo">
          <div class="photo-placeholder" style="aspect-ratio: 4/3; border-radius: 12px;">
            <span>[Photo : Ismaru Falbru dans le magasin Feedz]</span>
          </div>
        </div>
        <div class="about-text">
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.5rem, 3vw, 1.875rem); font-weight: 700; color: #2C1A0E; margin: 0 0 1rem;">
            {tr.about.heading}
          </h2>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; line-height: 1.7; color: #5C4A35; margin: 0 0 1.25rem;">
            {tr.about.body}
          </p>
          <a href={`/${lang}/a-propos/`} style="color: #2D6A4F; font-weight: 700; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; text-decoration: none;">
            {tr.about.linkText}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section style="background-color: #2D6A4F; padding: 3rem 1rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.5rem, 3vw, 1.875rem); font-weight: 700; color: #F5F0E8; margin: 0 0 2rem; text-align: center;">
        {tr.testimonials.heading}
      </h2>
      <div class="testimonials-grid">
        {tr.testimonials.items.map(item => (
          <div style="background: #F5F0E8; border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
            <svg width="28" height="20" viewBox="0 0 28 20" fill="#52B788" aria-hidden="true">
              <path d="M0 20V12.5C0 5.5 4.5 1.5 13.5 0l1.5 2.5C10.5 3.5 8 6 7.5 10H12V20H0zm16 0V12.5C16 5.5 20.5 1.5 29.5 0l1.5 2.5C26.5 3.5 24 6 23.5 10H28V20H16z"/>
            </svg>
            <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; line-height: 1.6; color: #2C1A0E; margin: 0; font-style: italic;">"{item.quote}"</p>
            <div>
              <div style="font-family: 'Nunito Sans', system-ui, sans-serif; font-weight: 700; font-size: 0.875rem; color: #2D6A4F;">{item.author}</div>
              <div style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.8125rem; color: #5C4A35;">{item.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LocationStrip lang={lang} />

  {latestTips.length > 0 && (
    <section style="padding: 3rem 1rem; background-color: #F5F0E8;">
      <div style="max-width: 1100px; margin: 0 auto;">
        <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 0.5rem;">
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.5rem, 3vw, 1.875rem); font-weight: 700; color: #2C1A0E; margin: 0;">
            {tr.tips.heading}
          </h2>
          <a href={`/${lang}/conseils/`} style="color: #2D6A4F; font-weight: 700; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; text-decoration: none;">
            {tr.tips.viewAll}
          </a>
        </div>
        <div class="tips-grid">
          {latestTips.map(tip => (
            <TipCard
              lang={lang}
              title={tip.data.title}
              description={tip.data.description}
              category={tip.data.category}
              date={tip.data.date}
              readTime={tip.data.readTime}
              slug={tip.id.replace(/^fr\//, '')}
              minRead={tr.tips.minRead}
              readMoreLabel={tr.tips.readMore.replace(' →', '')}
            />
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
  .hero-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .hero-photo { order: 1; }
  .hero-text { order: 2; }
  .hero-buttons { display: flex; flex-direction: column; gap: 0.75rem; }
  .cat-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .about-inner { display: flex; flex-direction: column; gap: 1.5rem; }
  .testimonials-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .tips-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }

  @media (min-width: 480px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 768px) {
    .hero-inner { flex-direction: row; align-items: center; gap: 3rem; }
    .hero-photo { order: 2; flex: 1; }
    .hero-text { order: 1; flex: 1.1; }
    .hero-buttons { flex-direction: row; }
    .cat-grid { grid-template-columns: repeat(3, 1fr); }
    .about-inner { flex-direction: row; align-items: center; gap: 3rem; }
    .about-photo { flex: 1; }
    .about-text { flex: 1.2; }
    .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
    .tips-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
