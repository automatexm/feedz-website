---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/index';

const lang = 'en' as const;
const tr = t(lang);
const waMessage = encodeURIComponent(tr.whatsapp.defaultMessage);
---

<Base title={tr.seo.contact.title} description={tr.seo.contact.description} lang={lang}>

  <!-- Page header -->
  <div style="background-color: #2D6A4F; padding: 3rem 1rem 2.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #F5F0E8; margin: 0;">
        {tr.contact.heading}
      </h1>
    </div>
  </div>

  <div style="max-width: 1100px; margin: 0 auto; padding: 2.5rem 1rem;">
    <div class="contact-grid">

      <!-- Left col: WhatsApp + Phone + Visit -->
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">

        <!-- WhatsApp (primary) -->
        <div style="background: #EAE0CC; border-radius: 12px; padding: 2rem; border: 2px solid #25D366;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <div style="width: 48px; height: 48px; background: #25D366; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.25rem; font-weight: 700; color: #2C1A0E; margin: 0;">
              {tr.contact.waHeading}
            </h2>
          </div>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; line-height: 1.6; color: #5C4A35; margin: 0 0 1.25rem;">
            {tr.contact.waBody}
          </p>
          <a
            href={`https://wa.me/17215810102?text=${waMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: #25D366; color: white; padding: 0.875rem 1.5rem; border-radius: 8px; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; text-decoration: none;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {tr.contact.waButton}
          </a>
        </div>

        <!-- Phone -->
        <div style="background: #EAE0CC; border-radius: 12px; padding: 1.5rem;">
          <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.125rem; font-weight: 700; color: #2C1A0E; margin: 0 0 0.5rem;">
            {tr.contact.phoneHeading}
          </h3>
          <a href="tel:+17215810102" style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1.25rem; font-weight: 700; color: #2D6A4F; text-decoration: none;">
            +1 721 581 0102
          </a>
        </div>

        <!-- Visit -->
        <div style="background: #EAE0CC; border-radius: 12px; padding: 1.5rem;">
          <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.125rem; font-weight: 700; color: #2C1A0E; margin: 0 0 1rem;">
            {tr.contact.visitHeading}
          </h3>
          <div style="display: flex; flex-direction: column; gap: 0.625rem; font-family: 'Nunito Sans', system-ui, sans-serif; margin-bottom: 1.25rem;">
            <div style="display: flex; gap: 0.5rem; align-items: flex-start;">
              <span style="flex-shrink: 0;" aria-hidden="true">📍</span>
              <span style="color: #5C4A35; font-size: 0.9375rem;">{tr.location.address}</span>
            </div>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
              <span style="flex-shrink: 0;" aria-hidden="true">🕐</span>
              <span style="color: #5C4A35; font-size: 0.9375rem;">{tr.location.hours}</span>
            </div>
          </div>
          <!-- Google Maps embed placeholder -->
          <div style="background: #F5F0E8; border: 2px dashed #52B788; border-radius: 8px; height: 280px; display: flex; align-items: center; justify-content: center; text-align: center; padding: 1rem;">
            <p style="font-style: italic; color: #5C4A35; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; margin: 0;">
              [Google Maps embed — address to be confirmed by Ismaru]<br />
              <span style="font-size: 0.8125rem; color: #52B788;">Replace with iframe from Google Maps</span>
            </p>
          </div>
        </div>

        <!-- Facebook -->
        <div style="background: #EAE0CC; border-radius: 12px; padding: 1.5rem;">
          <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.125rem; font-weight: 700; color: #2C1A0E; margin: 0 0 0.5rem;">
            {tr.contact.socialHeading}
          </h3>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; color: #5C4A35; margin: 0 0 1rem;">
            {tr.contact.socialBody}
          </p>
          <a
            href="https://facebook.com/feedzsxm"
            target="_blank"
            rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.5rem; background: #1877F2; color: white; padding: 0.625rem 1.25rem; border-radius: 6px; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; font-weight: 700; text-decoration: none;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            {tr.contact.socialButton}
          </a>
        </div>
      </div>

      <!-- Right col: Contact form -->
      <div>
        <div style="background: #EAE0CC; border-radius: 12px; padding: 2rem;">
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.375rem; font-weight: 700; color: #2C1A0E; margin: 0 0 1.5rem;">
            {tr.contact.formHeading}
          </h2>
          <form
            action="https://formspree.io/f/PLACEHOLDER"
            method="POST"
            style="display: flex; flex-direction: column; gap: 1rem;"
          >
            <div>
              <label for="name" style="display: block; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; font-weight: 600; color: #2C1A0E; margin-bottom: 0.375rem;">
                {tr.contact.formName}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                style="width: 100%; padding: 0.75rem 1rem; border: 1px solid #5C4A35; border-radius: 6px; background: white; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; color: #2C1A0E; box-sizing: border-box;"
              />
            </div>
            <div>
              <label for="email" style="display: block; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; font-weight: 600; color: #2C1A0E; margin-bottom: 0.375rem;">
                {tr.contact.formEmail}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                style="width: 100%; padding: 0.75rem 1rem; border: 1px solid #5C4A35; border-radius: 6px; background: white; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; color: #2C1A0E; box-sizing: border-box;"
              />
            </div>
            <div>
              <label for="message" style="display: block; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; font-weight: 600; color: #2C1A0E; margin-bottom: 0.375rem;">
                {tr.contact.formMessage}
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                style="width: 100%; padding: 0.75rem 1rem; border: 1px solid #5C4A35; border-radius: 6px; background: white; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; color: #2C1A0E; resize: vertical; box-sizing: border-box;"
              ></textarea>
            </div>
            <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.8125rem; color: #5C4A35; margin: 0;">
              {tr.contact.formNote}
            </p>
            <button
              type="submit"
              style="background: #D4A017; color: #2C1A0E; padding: 0.9375rem 1.5rem; border-radius: 8px; border: none; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; min-height: 48px;"
            >
              {tr.contact.formSubmit}
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

</Base>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }
</style>
