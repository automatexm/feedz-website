---
import Base from './Base.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { t, type Lang } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  date: Date;
  category: string;
  readTime: number;
}

const { title, description, lang, date, category, readTime } = Astro.props;
const tr = t(lang);

const formattedDate = new Intl.DateTimeFormat(lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const categoryColors: Record<string, string> = {
  horses: '#2D6A4F',
  pets: '#52B788',
  poultry: '#D4A017',
  livestock: '#5C4A35',
  birds: '#52B788',
  general: '#2D6A4F',
};
const catColor = categoryColors[category] ?? '#2D6A4F';
---

<Base title={title} description={description} lang={lang}>
  <div style="background-color: #2D6A4F; padding: 2rem 1rem;">
    <div style="max-width: 720px; margin: 0 auto;">
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap;">
        <span style={`background: ${catColor}; color: white; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;`}>
          {category}
        </span>
        <span style="color: #EAE0CC; font-size: 0.875rem;">{formattedDate}</span>
        <span style="color: #EAE0CC; font-size: 0.875rem;">· {readTime} {tr.tips.minRead}</span>
      </div>
      <h1 style="font-family: 'Playfair Display', Georgia, serif; color: #F5F0E8; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; line-height: 1.2; margin: 0;">{title}</h1>
    </div>
  </div>

  <div style="max-width: 720px; margin: 0 auto; padding: 2.5rem 1rem 4rem;">
    <div style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; line-height: 1.7; color: #5C4A35;">
      <slot />
    </div>

    <!-- WhatsApp CTA at end of article -->
    <div style="background-color: #2D6A4F; border-radius: 12px; padding: 2rem; margin-top: 3rem; text-align: center;">
      <h3 style="font-family: 'Playfair Display', Georgia, serif; color: #F5F0E8; font-size: 1.25rem; margin: 0 0 0.5rem;">
        {lang === 'fr' ? 'Des questions ? Écrivez-nous !' : 'Have questions? Chat with us!'}
      </h3>
      <p style="color: #EAE0CC; margin: 0 0 1.25rem; font-size: 0.9375rem;">
        {lang === 'fr'
          ? "L'équipe Feedz est là pour vous aider avec tous vos besoins en alimentation animale."
          : "The Feedz team is here to help with all your animal feed needs."}
      </p>
      <a
        href={`https://wa.me/17215810102?text=${encodeURIComponent(lang === 'fr' ? "Bonjour Feedz ! J'ai une question sur l'alimentation animale." : "Hello Feedz! I have a question about animal feed.")}`}
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: #25D366; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none;"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {tr.whatsapp.ctaLabel}
      </a>
    </div>

    <!-- Back link -->
    <div style="margin-top: 2rem; text-align: center;">
      <a href={`/${lang}/${lang === 'fr' ? 'conseils' : 'tips'}/`} style="color: #1B6CA8; font-size: 0.875rem;">
        ← {lang === 'fr' ? 'Tous les conseils' : 'All tips'}
      </a>
    </div>
  </div>
</Base>
