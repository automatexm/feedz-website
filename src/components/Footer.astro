---
import { t, type Lang } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

const navLinks = [
  { href: `/${lang}/`, label: tr.nav.home },
  { href: `/${lang}/products/`, label: tr.nav.products },
  { href: `/${lang}/about/`, label: tr.nav.about },
  { href: `/${lang}/${lang === 'fr' ? 'conseils' : 'tips'}/`, label: tr.nav.tips },
  { href: `/${lang}/contact/`, label: tr.nav.contact },
];
---

<footer style="background-color: #2C1A0E; color: #EAE0CC; padding: 3rem 1rem 1.5rem;">
  <div style="max-width: 1100px; margin: 0 auto;">

    <!-- Main footer grid -->
    <div style="display: grid; grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 2.5rem;">

      <!-- Brand column -->
      <div>
        <div style="margin-bottom: 1rem;">
          <span style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.75rem; font-weight: 700; color: #F5F0E8;">Feedz</span>
        </div>
        <p style="color: #EAE0CC; font-size: 0.9375rem; line-height: 1.6; margin: 0 0 1.25rem; font-family: 'Nunito Sans', system-ui, sans-serif;">
          {tr.footer.tagline}
        </p>
        <!-- Facebook link -->
        <a
          href="https://facebook.com/feedzsxm"
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 0.5rem; color: #EAE0CC; text-decoration: none; font-size: 0.875rem; font-family: 'Nunito Sans', system-ui, sans-serif;"
          aria-label="Follow Feedz on Facebook"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Facebook
        </a>
      </div>

      <!-- Nav column -->
      <div>
        <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; font-weight: 600; color: #F5F0E8; margin: 0 0 1rem; text-transform: uppercase; letter-spacing: 0.05em;">
          {tr.footer.nav}
        </h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                style="color: #EAE0CC; text-decoration: none; font-size: 0.9375rem; font-family: 'Nunito Sans', system-ui, sans-serif;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; font-weight: 600; color: #F5F0E8; margin: 0 0 1rem; text-transform: uppercase; letter-spacing: 0.05em;">
          {tr.footer.contact}
        </h3>
        <div style="display: flex; flex-direction: column; gap: 0.75rem; font-family: 'Nunito Sans', system-ui, sans-serif;">
          <a
            href={`https://wa.me/17215810102?text=${encodeURIComponent(tr.whatsapp.defaultMessage)}`}
            target="_blank"
            rel="noopener noreferrer"
            style="display: flex; align-items: center; gap: 0.5rem; color: #25D366; text-decoration: none; font-size: 0.9375rem; font-weight: 600;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            +1 721 581 0102
          </a>
          <span style="color: #EAE0CC; font-size: 0.9375rem;">📍 {tr.location.address}</span>
          <span style="color: #EAE0CC; font-size: 0.875rem;">🕐 {tr.location.hours}</span>
        </div>
      </div>
    </div>

    <!-- Bottom strip -->
    <div style="border-top: 1px solid rgba(245,240,232,0.15); padding-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem; align-items: center; text-align: center;">
      <!-- DW certification -->
      <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(245,240,232,0.08); padding: 0.5rem 1rem; border-radius: 6px; border: 1px solid rgba(245,240,232,0.15);">
        <span style="font-size: 0.75rem; color: #EAE0CC; font-family: 'Nunito Sans', system-ui, sans-serif;">
          🏆 {tr.footer.certifiedRetailer} — Dommelsche Watermolen
        </span>
      </div>
      <p style="color: rgba(234,224,204,0.6); font-size: 0.8125rem; margin: 0; font-family: 'Nunito Sans', system-ui, sans-serif;">
        {tr.footer.copyright}
      </p>
    </div>

  </div>
</footer>

<style>
  @media (min-width: 768px) {
    footer > div > div:first-child {
      grid-template-columns: 2fr 1fr 1.5fr !important;
    }
  }
</style>
