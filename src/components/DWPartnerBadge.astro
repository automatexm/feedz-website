---
import { t, type Lang } from '../i18n/index';

interface Props {
  lang: Lang;
  variant?: 'full' | 'compact';
}

const { lang, variant = 'full' } = Astro.props;
const tr = t(lang);
---

{variant === 'full' ? (
  <section style="background-color: #EAE0CC; padding: 3rem 1rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="dw-inner">
        <!-- Logo -->
        <div style="flex-shrink: 0;">
          <img src="/images/dommelsche-logo.jpg" alt={tr.dw.logoAlt} style="height: 80px; width: auto; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />
          <div style="text-align: center; margin-top: 0.5rem;">
            <span style="background: #2D6A4F; color: white; font-size: 0.6875rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 4px; font-family: 'Nunito Sans', system-ui, sans-serif; letter-spacing: 0.05em; text-transform: uppercase;">
              {tr.dw.badge}
            </span>
          </div>
        </div>

        <!-- Text -->
        <div style="flex: 1;">
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
            <span style="background: #2D6A4F; color: white; font-size: 0.6875rem; font-weight: 700; padding: 0.25rem 0.625rem; border-radius: 4px; font-family: 'Nunito Sans', system-ui, sans-serif; text-transform: uppercase; letter-spacing: 0.05em;">
              {tr.dw.certifiedRetailer}
            </span>
          </div>
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.25rem, 3vw, 1.625rem); font-weight: 700; color: #2C1A0E; margin: 0 0 0.75rem;">
            {tr.dw.heading}
          </h2>
          <p style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1rem; line-height: 1.6; color: #5C4A35; margin: 0 0 1rem;">
            {tr.dw.body}
          </p>
          <a
            href="https://www.dommelschewatermolen.nl"
            target="_blank"
            rel="noopener noreferrer"
            style="color: #1B6CA8; font-size: 0.9375rem; font-family: 'Nunito Sans', system-ui, sans-serif; font-weight: 600;"
          >
            {tr.dw.link}
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <!-- Compact variant for Products page -->
  <div style="background: #EAE0CC; border: 1px solid #2D6A4F; border-radius: 8px; padding: 1rem 1.25rem; display: flex; align-items: center; gap: 1rem;">
    <img src="/images/dommelsche-logo.jpg" alt={tr.dw.logoAlt} style="height: 48px; width: auto; border-radius: 6px; flex-shrink: 0;" />
    <div>
      <div style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.8125rem; font-weight: 700; color: #2D6A4F; text-transform: uppercase; letter-spacing: 0.05em;">
        {tr.dw.certifiedRetailer}
      </div>
      <div style="font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.875rem; color: #5C4A35;">
        Dommelsche Watermolen — {tr.dw.badge}
      </div>
    </div>
  </div>
)}

<style>
  .dw-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .dw-inner {
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
    }
  }
</style>
