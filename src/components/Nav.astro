---
import { t, type Lang } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `/${lang}/`, label: tr.nav.home },
  { href: `/${lang}/products/`, label: tr.nav.products },
  { href: `/${lang}/about/`, label: tr.nav.about },
  { href: `/${lang}/${lang === 'fr' ? 'conseils' : 'tips'}/`, label: tr.nav.tips },
  { href: `/${lang}/contact/`, label: tr.nav.contact },
];

const waMessage = encodeURIComponent(tr.whatsapp.defaultMessage);
const waUrl = `https://wa.me/17215810102?text=${waMessage}`;
---

<header style="background-color: #2D6A4F; position: sticky; top: 0; z-index: 50; box-shadow: 0 2px 8px rgba(44,26,14,0.15);">
  <div style="max-width: 1100px; margin: 0 auto; padding: 0 1rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; height: 64px;">

      <!-- Logo -->
      <a href={`/${lang}/`} style="text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
        <img src="/images/feedz-logo.jpg" alt="Feedz" style="height: 56px; width: auto; border-radius: 4px;" />
        <span style="display: none; font-size: 0.75rem; color: #EAE0CC; font-family: 'Nunito Sans', system-ui, sans-serif; padding-left: 0.5rem; border-left: 1px solid rgba(245,240,232,0.3);" class="logo-tagline">Sint Maarten</span>
      </a>

      <!-- Desktop nav -->
      <nav style="display: none;" class="desktop-nav" aria-label="Main navigation">
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: 0.25rem;">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                style={`display: block; padding: 0.5rem 0.75rem; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 0.9375rem; font-weight: 600; color: #F5F0E8; text-decoration: none; border-radius: 6px; transition: background 0.15s; ${currentPath === link.href || currentPath.startsWith(link.href.replace(/\/$/, '')) && link.href !== `/${lang}/` ? 'border-bottom: 2px solid #D4A017;' : ''}`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Right side: lang toggle + WA button + hamburger -->
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <!-- Language toggle -->
        <div style="display: flex; border: 1px solid rgba(245,240,232,0.4); border-radius: 6px; overflow: hidden;">
          <a
            href={`/en/`}
            style={`display: flex; align-items: center; gap: 0.375rem; padding: 0.375rem 0.625rem; font-size: 0.8125rem; font-weight: 700; font-family: 'Nunito Sans', system-ui, sans-serif; text-decoration: none; transition: background 0.15s; ${lang === 'en' ? 'background: #F5F0E8; color: #2D6A4F;' : 'color: #F5F0E8;'}`}
          >
            <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true" style="border-radius: 2px; box-shadow: 0 0 0 1px rgba(255,255,255,0.2);">
              <rect width="16" height="12" fill="#B22234"/>
              <rect y="0.92" width="16" height="0.92" fill="white"/>
              <rect y="2.77" width="16" height="0.92" fill="white"/>
              <rect y="4.62" width="16" height="0.92" fill="white"/>
              <rect y="6.46" width="16" height="0.92" fill="white"/>
              <rect y="8.31" width="16" height="0.92" fill="white"/>
              <rect y="10.15" width="16" height="0.92" fill="white"/>
              <rect width="6.4" height="6.46" fill="#3C3B6E"/>
            </svg>
            EN
          </a>
          <a
            href={`/fr/`}
            style={`display: flex; align-items: center; gap: 0.375rem; padding: 0.375rem 0.625rem; font-size: 0.8125rem; font-weight: 700; font-family: 'Nunito Sans', system-ui, sans-serif; text-decoration: none; transition: background 0.15s; border-left: 1px solid rgba(245,240,232,0.4); ${lang === 'fr' ? 'background: #F5F0E8; color: #2D6A4F;' : 'color: #F5F0E8;'}`}
          >
            <svg width="16" height="12" viewBox="0 0 16 12" aria-hidden="true" style="border-radius: 2px; box-shadow: 0 0 0 1px rgba(255,255,255,0.2);">
              <rect width="5.33" height="12" fill="#002395"/>
              <rect x="5.33" width="5.33" height="12" fill="white"/>
              <rect x="10.67" width="5.33" height="12" fill="#ED2939"/>
            </svg>
            FR
          </a>
        </div>

        <!-- WA button (desktop only) -->
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display: none; align-items: center; gap: 0.375rem; background: #25D366; color: white; padding: 0.4375rem 0.875rem; border-radius: 6px; font-size: 0.875rem; font-weight: 700; font-family: 'Nunito Sans', system-ui, sans-serif; text-decoration: none;"
          class="wa-nav-btn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {tr.nav.chatWithUs}
        </a>

        <!-- Hamburger (mobile) -->
        <button
          id="menu-toggle"
          aria-label="Toggle menu"
          aria-expanded="false"
          style="display: flex; flex-direction: column; gap: 4px; padding: 0.5rem; cursor: pointer; background: none; border: none; color: #F5F0E8;"
          class="hamburger"
        >
          <span style="display: block; width: 22px; height: 2px; background: currentColor; transition: transform 0.2s;"></span>
          <span style="display: block; width: 22px; height: 2px; background: currentColor; transition: opacity 0.2s;"></span>
          <span style="display: block; width: 22px; height: 2px; background: currentColor; transition: transform 0.2s;"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    style="display: none; background-color: #2D6A4F; border-top: 1px solid rgba(245,240,232,0.2); padding: 1rem;"
    aria-hidden="true"
  >
    <nav aria-label="Mobile navigation">
      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.25rem;">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              style="display: block; padding: 1rem; font-family: 'Nunito Sans', system-ui, sans-serif; font-size: 1.125rem; font-weight: 600; color: #F5F0E8; text-decoration: none; border-radius: 8px; min-height: 48px;"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid rgba(245,240,232,0.2);">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; background: #25D366; color: white; padding: 0.875rem; border-radius: 8px; font-size: 1rem; font-weight: 700; font-family: 'Nunito Sans', system-ui, sans-serif; text-decoration: none;"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {tr.nav.chatWithUs}
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  @media (min-width: 1024px) {
    .desktop-nav { display: flex !important; }
    .wa-nav-btn { display: flex !important; }
    .hamburger { display: none !important; }
    .logo-tagline { display: inline !important; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.style.display === 'block';
      menu.style.display = isOpen ? 'none' : 'block';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
    });
  }
</script>
